DROP PROCEDURE IF EXISTS sp_cart_add_item $$\\par
CREATE PROCEDURE sp_cart_add_item(\\par
    IN p_staff_id BIGINT,\\par
    IN p_product_id BIGINT,\\par
    IN p_quantity INT\\par
)\\par
BEGIN\\par
    DECLARE v_cart_id BIGINT;\\par
    DECLARE v_item_id BIGINT;\\par
    DECLARE v_name VARCHAR(200);\\par
    DECLARE v_bar_code VARCHAR(50);\\par
    DECLARE v_image_link VARCHAR(255);\\par
    DECLARE v_price INT;\\par
\\par
    CALL sp_cart_ensure_open(p_staff_id);\\par
\\par
    SELECT id INTO v_cart_id\\par
    FROM staff_carts\\par
    WHERE sale_people_id = p_staff_id\\par
      AND cart_status = 'OPEN'\\par
    ORDER BY id DESC\\par
    LIMIT 1;\\par
\\par
    SELECT name, bar_code, image_link, price_sale\\par
    INTO v_name, v_bar_code, v_image_link, v_price\\par
    FROM products\\par
    WHERE id = p_product_id\\par
      AND is_deleted = FALSE;\\par
\\par
    SELECT id INTO v_item_id\\par
    FROM staff_cart_items\\par
    WHERE cart_id = v_cart_id\\par
      AND product_id = p_product_id\\par
    LIMIT 1;\\par
\\par
    IF v_item_id IS NULL THEN\\par
        INSERT INTO staff_cart_items(\\par
            cart_id, product_id, name, bar_code, image_link, sale_price, quantity, total_money\\par
        ) VALUES (\\par
            v_cart_id, p_product_id, v_name, v_bar_code, v_image_link, v_price, p_quantity, v_price * p_quantity\\par
        );\\par
    ELSE\\par
        UPDATE staff_cart_items\\par
        SET quantity = quantity + p_quantity,\\par
            total_money = (quantity + p_quantity) * sale_price,\\par
            updated_at = NOW()\\par
        WHERE id = v_item_id;\\par
    END IF;\\par
\\par
    SELECT TRUE AS success;\\par
END $$\\par
\\par
