DROP PROCEDURE IF EXISTS sp_statistical_summary $$\\par
CREATE PROCEDURE sp_statistical_summary()\\par
BEGIN\\par
    SELECT COALESCE(SUM(total_money), 0) AS total_money,\\par
           COALESCE(SUM(quantity), 0) AS total_quantity,\\par
           COUNT(*) AS invoice_number\\par
    FROM invoices\\par
    WHERE invoice_status <> 'CANCELLED';\\par
END $$\\par
\\par
DROP PROCEDURE IF EXISTS sp_statistical_summary_with_users $$\\par
CREATE PROCEDURE sp_statistical_summary_with_users()\\par
BEGIN\\par
    SELECT\\par
        (SELECT COALESCE(SUM(total_money), 0) FROM invoices WHERE invoice_status <> 'CANCELLED') AS money,\\par
        (SELECT COALESCE(SUM(quantity), 0) FROM invoices WHERE invoice_status <> 'CANCELLED') AS quantity,\\par
        (SELECT COUNT(*) FROM invoices WHERE invoice_status <> 'CANCELLED') AS invoice_number,\\par
        (\\par
            SELECT COUNT(*)\\par
            FROM users u\\par
            JOIN user_role ur ON ur.user_id = u.id\\par
            JOIN roles r ON r.id = ur.role_id\\par
            WHERE r.role_code = 'STAFF'\\par
              AND u.is_deleted = FALSE\\par
        ) AS user_number;\\par
END $$\\par
\\par
DROP PROCEDURE IF EXISTS sp_statistical_by_date $$\\par
CREATE PROCEDURE sp_statistical_by_date(\\par
    IN p_start_date DATETIME,\\par
    IN p_end_date DATETIME\\par
)\\par
BEGIN\\par
    SELECT i.invoice_code,\\par
           u.full_name AS sale_people,\\par
           c.full_name AS customer_name,\\par
           i.receive_money,\\par
           i.excess_money,\\par
           i.total_money,\\par
           i.quantity,\\par
           i.created_date\\par
    FROM invoices i\\par
    JOIN customers c ON c.id = i.customer_id\\par
    JOIN users u ON u.id = i.user_id\\par
    WHERE i.created_date BETWEEN p_start_date AND p_end_date\\par
      AND i.invoice_status <> 'CANCELLED'\\par
    ORDER BY i.created_date DESC;\\par
END $$\\par
\\par
DROP PROCEDURE IF EXISTS sp_statistical_staff_revenue $$\\par
CREATE PROCEDURE sp_statistical_staff_revenue()\\par
BEGIN\\par
    SELECT u.id AS user_id,\\par
           u.full_name,\\par
           COUNT(i.id) AS invoice_count,\\par
           COALESCE(SUM(i.quantity), 0) AS total_quantity,\\par
           COALESCE(SUM(i.total_money), 0) AS total_revenue\\par
    FROM users u\\par
    JOIN user_role ur ON ur.user_id = u.id\\par
    JOIN roles r ON r.id = ur.role_id\\par
    LEFT JOIN invoices i\\par
        ON i.user_id = u.id\\par
       AND i.invoice_status <> 'CANCELLED'\\par
    WHERE r.role_code = 'STAFF'\\par
      AND u.is_deleted = FALSE\\par
    GROUP BY u.id, u.full_name\\par
    ORDER BY total_revenue DESC, invoice_count DESC, u.full_name ASC;\\par
END $$\\par
\\par
