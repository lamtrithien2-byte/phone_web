DROP PROCEDURE IF EXISTS sp_customer_create_if_not_exists $$\\par
CREATE PROCEDURE sp_customer_create_if_not_exists(\\par
    IN p_phone_number VARCHAR(20),\\par
    IN p_full_name VARCHAR(150),\\par
    IN p_address VARCHAR(255)\\par
)\\par
BEGIN\\par
    DECLARE v_customer_id BIGINT;\\par
    DECLARE v_next_customer_no BIGINT;\\par
\\par
    SELECT id INTO v_customer_id\\par
    FROM customers\\par
    WHERE phone_number = p_phone_number\\par
      AND is_deleted = FALSE\\par
    LIMIT 1;\\par
\\par
    IF v_customer_id IS NULL THEN\\par
        SELECT COALESCE(MAX(id), 0) + 1 INTO v_next_customer_no\\par
        FROM customers;\\par
\\par
        INSERT INTO customers(customer_code, phone_number, full_name, address)\\par
        VALUES (\\par
            CONCAT('CUS', LPAD(v_next_customer_no, 4, '0')),\\par
            p_phone_number,\\par
            p_full_name,\\par
            p_address\\par
        );\\par
        SET v_customer_id = LAST_INSERT_ID();\\par
    ELSE\\par
        UPDATE customers\\par
        SET full_name = COALESCE(NULLIF(p_full_name, ''), full_name),\\par
            address = COALESCE(NULLIF(p_address, ''), address),\\par
            updated_at = NOW()\\par
        WHERE id = v_customer_id;\\par
    END IF;\\par
\\par
    SELECT v_customer_id AS customer_id;\\par
END $$\\par
