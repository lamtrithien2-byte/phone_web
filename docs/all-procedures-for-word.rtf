DROP PROCEDURE IF EXISTS sp_invoice_item_create $$\\par
CREATE PROCEDURE sp_invoice_item_create(\\par
    IN p_invoice_id BIGINT,\\par
    IN p_product_id BIGINT,\\par
    IN p_quantity INT,\\par
    IN p_unit_price INT\\par
)\\par
BEGIN\\par
    DECLARE v_product_name VARCHAR(200);\\par
    DECLARE v_bar_code VARCHAR(50);\\par
    DECLARE v_quantity_after INT;\\par
\\par
    SELECT name, bar_code\\par
    INTO v_product_name, v_bar_code\\par
    FROM products\\par
    WHERE id = p_product_id;\\par
\\par
    INSERT INTO invoice_items(\\par
        invoice_id, product_id, product_name, bar_code, quantity, unit_price, line_total\\par
    ) VALUES (\\par
        p_invoice_id, p_product_id, v_product_name, v_bar_code, p_quantity, p_unit_price, p_quantity * p_unit_price\\par
    );\\par
\\par
    UPDATE products\\par
    SET sale_number = sale_number + p_quantity,\\par
        stock_quantity = stock_quantity - p_quantity,\\par
        updated_date = NOW()\\par
    WHERE id = p_product_id;\\par
\\par
    SELECT stock_quantity INTO v_quantity_after\\par
    FROM products\\par
    WHERE id = p_product_id;\\par
\\par
    INSERT INTO inventory_transactions(\\par
        product_id, transaction_type, quantity_change, quantity_after,\\par
        reference_type, reference_id, note, created_by\\par
    ) VALUES (\\par
        p_product_id,\\par
        'SALE',\\par
        -p_quantity,\\par
        v_quantity_after,\\par
        'INVOICE',\\par
        p_invoice_id,\\par
        'Ban hang tai quay',\\par
        NULL\\par
    );\\par
\\par
    SELECT LAST_INSERT_ID() AS invoice_item_id;\\par
END $$\\par
