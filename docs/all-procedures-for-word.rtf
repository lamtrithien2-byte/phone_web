DROP PROCEDURE IF EXISTS sp_product_search $$\\par
CREATE PROCEDURE sp_product_search(IN p_keyword VARCHAR(150))\\par
BEGIN\\par
    SELECT p.id,\\par
           p.bar_code,\\par
           p.name,\\par
           p.screen_size,\\par
           p.ram,\\par
           p.rom,\\par
           p.import_price,\\par
           p.price_sale,\\par
           p.description,\\par
           p.image_link,\\par
           p.sale_number,\\par
           p.created_date,\\par
           p.updated_date,\\par
           p.is_deleted,\\par
           c.category_name\\par
    FROM products p\\par
    JOIN categories c ON c.id = p.category_id\\par
    LEFT JOIN brands b ON b.id = p.brand_id\\par
    WHERE p.is_deleted = FALSE\\par
      AND (\\par
          p.bar_code LIKE CONCAT('%', p_keyword, '%')\\par
          OR p.sku LIKE CONCAT('%', p_keyword, '%')\\par
          OR p.name LIKE CONCAT('%', p_keyword, '%')\\par
          OR c.category_name LIKE CONCAT('%', p_keyword, '%')\\par
          OR COALESCE(b.brand_name, '') LIKE CONCAT('%', p_keyword, '%')\\par
      )\\par
    ORDER BY p.sale_number DESC, p.created_date DESC;\\par
END $$\\par
