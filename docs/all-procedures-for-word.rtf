DROP PROCEDURE IF EXISTS sp_auth_login $$\\par
CREATE PROCEDURE sp_auth_login(IN p_user_name VARCHAR(100))\\par
BEGIN\\par
    SELECT u.id,\\par
           u.user_name,\\par
           u.password_hash,\\par
           u.full_name,\\par
           u.email,\\par
           u.address,\\par
           u.phone_number,\\par
           u.avatar,\\par
           u.activation_token,\\par
           u.is_activated,\\par
           u.first_login,\\par
           u.is_deleted,\\par
           r.role_code AS role_name\\par
    FROM users u\\par
    JOIN user_role ur ON ur.user_id = u.id\\par
    JOIN roles r ON r.id = ur.role_id\\par
    WHERE u.user_name = p_user_name\\par
      AND u.is_deleted = FALSE\\par
    ORDER BY r.id\\par
    LIMIT 1;\\par
END $$\\par
\\par
DROP PROCEDURE IF EXISTS sp_auth_create_staff $$\\par
CREATE PROCEDURE sp_auth_create_staff(\\par
    IN p_user_name VARCHAR(100),\\par
    IN p_password_hash VARCHAR(255),\\par
    IN p_full_name VARCHAR(150),\\par
    IN p_email VARCHAR(150),\\par
    IN p_address VARCHAR(255),\\par
    IN p_phone_number VARCHAR(20),\\par
    IN p_activation_token VARCHAR(255),\\par
    IN p_activation_expires DATETIME\\par
)\\par
BEGIN\\par
    DECLARE v_user_id BIGINT;\\par
    DECLARE v_role_id BIGINT;\\par
\\par
    INSERT INTO users(\\par
        user_name, password_hash, full_name, email, address, phone_number,\\par
        activation_token, activation_expires, is_activated, first_login, is_deleted\\par
    ) VALUES (\\par
        p_user_name, p_password_hash, p_full_name, p_email, p_address, p_phone_number,\\par
        p_activation_token, p_activation_expires, IF(p_activation_token IS NULL, TRUE, FALSE), TRUE, FALSE\\par
    );\\par
\\par
    SET v_user_id = LAST_INSERT_ID();\\par
    SELECT id INTO v_role_id FROM roles WHERE role_code = 'STAFF' LIMIT 1;\\par
    INSERT INTO user_role(user_id, role_id) VALUES (v_user_id, v_role_id);\\par
\\par
    CALL sp_audit_log_add(v_user_id, 'AUTH', 'CREATE_STAFF', 'users', v_user_id, JSON_OBJECT('user_name', p_user_name));\\par
\\par
    SELECT v_user_id AS user_id;\\par
END $$\\par
