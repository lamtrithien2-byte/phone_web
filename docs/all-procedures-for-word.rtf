DROP PROCEDURE IF EXISTS sp_auth_activate_account $$\\par
CREATE PROCEDURE sp_auth_activate_account(IN p_token VARCHAR(255))\\par
BEGIN\\par
    UPDATE users\\par
    SET is_activated = TRUE,\\par
        activation_token = NULL,\\par
        activation_expires = NULL,\\par
        updated_at = NOW()\\par
    WHERE activation_token = p_token\\par
      AND is_deleted = FALSE\\par
      AND (activation_expires IS NULL OR activation_expires >= NOW());\\par
\\par
    SELECT ROW_COUNT() AS affected_rows;\\par
END $$\\par
