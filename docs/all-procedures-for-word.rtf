DROP PROCEDURE IF EXISTS sp_product_adjust_stock $$\\par
CREATE PROCEDURE sp_product_adjust_stock(\\par
    IN p_product_id BIGINT,\\par
    IN p_quantity_change INT,\\par
    IN p_reference_type VARCHAR(30),\\par
    IN p_reference_id BIGINT,\\par
    IN p_note VARCHAR(255),\\par
    IN p_created_by BIGINT\\par
)\\par
BEGIN\\par
    DECLARE v_new_quantity INT;\\par
\\par
    UPDATE products\\par
    SET stock_quantity = stock_quantity + p_quantity_change,\\par
        updated_date = NOW()\\par
    WHERE id = p_product_id\\par
      AND is_deleted = FALSE;\\par
\\par
    SELECT stock_quantity INTO v_new_quantity\\par
    FROM products\\par
    WHERE id = p_product_id;\\par
\\par
    INSERT INTO inventory_transactions(\\par
        product_id, transaction_type, quantity_change, quantity_after,\\par
        reference_type, reference_id, note, created_by\\par
    ) VALUES (\\par
        p_product_id,\\par
        CASE\\par
            WHEN p_quantity_change > 0 THEN 'ADJUST_IN'\\par
            ELSE 'ADJUST_OUT'\\par
        END,\\par
        p_quantity_change,\\par
        v_new_quantity,\\par
        p_reference_type,\\par
        p_reference_id,\\par
        p_note,\\par
        p_created_by\\par
    );\\par
\\par
    SELECT v_new_quantity AS stock_quantity;\\par
END $$\\par
\\par
DROP PROCEDURE IF EXISTS sp_product_increase_sale_number $$\\par
CREATE PROCEDURE sp_product_increase_sale_number(\\par
    IN p_product_id BIGINT,\\par
    IN p_quantity INT\\par
)\\par
BEGIN\\par
    DECLARE v_quantity_after INT;\\par
\\par
    UPDATE products\\par
    SET sale_number = sale_number + p_quantity,\\par
        stock_quantity = stock_quantity - p_quantity,\\par
        updated_date = NOW()\\par
    WHERE id = p_product_id\\par
      AND is_deleted = FALSE;\\par
\\par
    SELECT stock_quantity INTO v_quantity_after\\par
    FROM products\\par
    WHERE id = p_product_id;\\par
\\par
    INSERT INTO inventory_transactions(\\par
        product_id, transaction_type, quantity_change, quantity_after,\\par
        reference_type, reference_id, note, created_by\\par
    ) VALUES (\\par
        p_product_id,\\par
        'SALE',\\par
        -p_quantity,\\par
        v_quantity_after,\\par
        'PRODUCT',\\par
        p_product_id,\\par
        'Tang doanh so ban',\\par
        NULL\\par
    );\\par
\\par
    SELECT ROW_COUNT() AS affected_rows;\\par
END $$\\par
